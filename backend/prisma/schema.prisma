// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  admin
  customer
}

model User {
  id           String   @id @default(uuid())
  full_name    String   @db.VarChar(100)
  email        String   @unique @db.VarChar(100)
  password     String   @db.VarChar(255)
  phone_number String?  @db.VarChar(20)
  role         Role     @default(customer)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  bookings     Booking[]

  @@map("users")
}

model TourPackage {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(150)
  destination String    @db.VarChar(100)
  description String    @db.Text
  price       Decimal   @db.Decimal(12, 2)
  quota       Int
  start_date  DateTime  @db.Date
  end_date    DateTime  @db.Date
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  bookings    Booking[]

  @@map("tour_packages")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

model Booking {
  id              String        @id @default(uuid())
  user_id         String
  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tour_package_id String
  tour_package    TourPackage   @relation(fields: [tour_package_id], references: [id], onDelete: Cascade)
  booking_code    String        @unique @db.VarChar(50)
  booking_date    DateTime
  total_pax       Int
  total_amount    Decimal       @db.Decimal(12, 2)
  status          BookingStatus @default(pending)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  payments        Payment[]

  @@map("bookings")
}

enum PaymentStatus {
  unpaid
  success
  failed
}

model Payment {
  id             String        @id @default(uuid())
  booking_id     String
  booking        Booking       @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  payment_method String        @db.VarChar(50)
  amount_paid    Decimal       @db.Decimal(12, 2)
  payment_date   DateTime?
  status         PaymentStatus @default(unpaid)
  proof_image    String?       @db.VarChar(255)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  @@map("payments")
}
